# Copy ke .env dan GANTI password sebelum expose ke internet!
AUTH_USERNAME=admin
AUTH_PASSWORD=Affiliate@2026

# Masa trial default saat admin menyetujui user baru (hari)
DEFAULT_TRIAL_DAYS=30

# Secret untuk webhook payment gateway (nanti)
# PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# Generate random: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Local: false | Railway: auto true (atau set manual)
COOKIE_SECURE=false

# Railway — opsional, auto dari RAILWAY_PUBLIC_DOMAIN jika kosong
# PUBLIC_BASE_URL=https://your-app.up.railway.app

# OAuth redirect (opsional, default auto dari PUBLIC_BASE_URL)
# YOUTUBE_REDIRECT_URI=https://your-app.up.railway.app/api/youtube/oauth/callback
# FACEBOOK_REDIRECT_URI=https://your-app.up.railway.app/api/facebook/oauth/callback
# THREADS_REDIRECT_URI=https://your-app.up.railway.app/api/threads/oauth/callback

# AI Title Generator — disarankan atur di Settings UI (OpenAI + Gemini backup)
# Legacy: key di .env auto-import ke Settings saat DB masih kosong
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=AIza...  (atau tambah via Settings → Google Gemini)