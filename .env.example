# Copy ke .env dan GANTI password sebelum expose ke internet!
AUTH_USERNAME=admin
AUTH_PASSWORD=Affiliate@2026

# Generate random: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Local: false | Railway / HTTPS: true
COOKIE_SECURE=false

# YouTube OAuth redirect (opsional, default auto dari server URL)
# YOUTUBE_REDIRECT_URI=http://localhost:8080/api/youtube/oauth/callback

# AI Title Generator — disarankan atur di Settings UI (OpenAI + Gemini backup)
